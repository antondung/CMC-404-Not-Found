# Citizen portal -> BE3 API base URL (baked into the JS bundle at BUILD time).
#
# Local:
#   VITE_API_URL=http://localhost:8000
#
# Railway (REQUIRED — otherwise browser calls localhost → "Failed to fetch"):
#   1. Open Backend service → Settings → Networking → generate Public Domain
#   2. Copy https://….up.railway.app (NOT *.railway.internal)
#   3. On Citizen Frontend service → Variables:
#        VITE_API_URL=https://YOUR-BACKEND.up.railway.app
#   4. Redeploy Frontend (Vite reads VITE_* only at build)
#
# Backend service must also have:
#   CORS_ALLOW_ALL=true
#   PORT=${{PORT}}  (Railway injects this; start: uvicorn app.main:app --host 0.0.0.0 --port $PORT)
VITE_API_URL=http://localhost:8000
# Router/asset base. Use `/` on Railway (app at domain root).
# VITE_BASE_PATH=/
